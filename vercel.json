{
  "rewrites": [
    { "source": "/api/webhooks/:workflowId", "destination": "/api/webhooks/[workflowId]" },
    { "source": "/api/executions/:id", "destination": "/api/executions/[id]" },
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
